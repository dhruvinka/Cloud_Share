spring.application.name=cloud

spring.data.mongodb.uri=YOUR_MONGODB_URI

spring.autoconfigure.exclude=org.springframework.boot.autoconfigure.security.servlet.UserDetailsServiceAutoConfiguration
clerk.issuer=YOUR_CLERK_ISSUER_URL
clerk.jwks.url=YOUR_CLERK_JWKS_URL
clerk.webhook.secret=YOUR_CLERK_WEBHOOK_SECRET

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=25MB

razorpay.key.secret=YOUR_RAZORPAY_SECRET
razorpay.key.id=YOUR_RAZORPAY_KEY_ID

aws.accessKeyId=YOUR_AWS_ACCESS_KEY
aws.secretKey=YOUR_AWS_SECRET_KEY
aws.region=us-east-1
aws.s3.bucket=YOUR_S3_BUCKET_NAME

virustotal.api.key=YOUR_VIRUSTOTAL_API_KEY
